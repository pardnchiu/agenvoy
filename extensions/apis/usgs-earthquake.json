{
  "name": "usgs_earthquake",
  "description": "透過 USGS Earthquake Hazards API 查詢全球即時或歷史地震資料，包含震級、深度、位置與時間。無需 API Key。",
  "endpoint": {
    "url": "https://earthquake.usgs.gov/fdsnws/event/1/query",
    "method": "GET",
    "content_type": "json",
    "timeout": 15
  },
  "parameters": {
    "format": {
      "type": "string",
      "description": "回應格式",
      "required": false,
      "default": "geojson",
      "enum": ["geojson", "csv", "text"]
    },
    "starttime": {
      "type": "string",
      "description": "查詢起始時間（ISO 8601 格式），例如 2024-01-01 或 2024-01-01T00:00:00",
      "required": false
    },
    "endtime": {
      "type": "string",
      "description": "查詢結束時間（ISO 8601 格式）。未指定則至今",
      "required": false
    },
    "minmagnitude": {
      "type": "number",
      "description": "最小震級（黎克特制），例如 5.0",
      "required": false
    },
    "maxmagnitude": {
      "type": "number",
      "description": "最大震級",
      "required": false
    },
    "latitude": {
      "type": "number",
      "description": "中心點緯度（搭配 longitude、maxradiuskm 使用）",
      "required": false
    },
    "longitude": {
      "type": "number",
      "description": "中心點經度",
      "required": false
    },
    "maxradiuskm": {
      "type": "number",
      "description": "搜尋半徑（公里），最大 20001.6",
      "required": false
    },
    "limit": {
      "type": "integer",
      "description": "最多回傳筆數（最大 20000）",
      "required": false,
      "default": 20
    },
    "orderby": {
      "type": "string",
      "description": "排序方式",
      "required": false,
      "default": "time",
      "enum": ["time", "time-asc", "magnitude", "magnitude-asc"]
    }
  },
  "response": {
    "format": "json"
  }
}
